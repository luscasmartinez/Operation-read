# Caminho local do arquivo JSON da Service Account.
# Em produção (Cloud Run) isso é montado via Secret Manager — ver README.
GOOGLE_APPLICATION_CREDENTIALS=credentials/service-account.json

# ID da pasta "Aegea" no Google Drive (pegue da URL da pasta)
GOOGLE_DRIVE_FOLDER_ID=

PORT=8080
ENVIRONMENT=development

# Domínio(s) do frontend autorizados a chamar a API, separados por vírgula.
# Em produção, coloque a URL da Vercel: https://seu-projeto.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173

REFRESH_INTERVAL_SECONDS=60
CACHE_DIR=.cache
